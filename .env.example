# =========================================================
# SERVICE PROVIDER CLIENT - ENVIRONMENT VARIABLES EXAMPLE
# =========================================================
# Copy this file to .env.local and fill in your actual values
# IMPORTANT: Never commit .env.local to version control!
# NOTE: All variables must be prefixed with VITE_ to be exposed to client code

# =========================================================
# Firebase Configuration
# =========================================================
# Get these credentials from Firebase Console:
# 1. Go to Firebase Console (https://console.firebase.google.com/)
# 2. Select your project
# 3. Click Settings (gear icon) > Project Settings
# 4. Go to "Your apps" section
# 5. Find your web app and copy the config

VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-name.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_name.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# =========================================================
# Backend API Configuration
# =========================================================
# For local development (backend running on localhost:8000)
VITE_API_BASE_URL=http://localhost:8000

# For production (deployed backend)
# VITE_API_BASE_URL=https://service-provider-server-cyan.vercel.app

# =========================================================
# Zego Video Conference Configuration
# =========================================================
# Get these from Zego Console (https://console.zegocloud.com/)
# 1. Create a project in Zego Console
# 2. Copy App ID and Server Secret from project settings
# 3. Keep Server Secret secure - never expose in client code

VITE_ZEGO_APP_ID=your_zego_app_id_here
VITE_ZEGO_SERVER_SECRET=your_zego_server_secret_here

# =========================================================
# Cloudinary Configuration (Image Upload & Optimization)
# =========================================================
# Get this from Cloudinary Dashboard (https://cloudinary.com/)
# 1. Sign up / Log in to Cloudinary
# 2. Go to Dashboard
# 3. Copy your Cloud Name from the API Environment Variable

VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# =========================================================
# Application Configuration (Optional)
# =========================================================
# You can add any other app-specific variables here
# Example:
# VITE_APP_NAME=Service Provider
# VITE_APP_VERSION=1.0.0
